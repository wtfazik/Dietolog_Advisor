APP_NAME=Professional Dietologist
APP_ENV=development
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
DEFAULT_LOCALE=ru

DATABASE_URL=postgresql://user:password@localhost:5432/professional_dietologist
DATABASE_REQUIRE_SSL=false

TELEGRAM_BOT_TOKEN=
SUPERADMIN_TELEGRAM_ID=

OPENROUTER_API_KEY=
GROQ_API_KEY=
HYPERBOLIC_API_KEY=

ADMIN_PANEL_USERNAME=admin
ADMIN_PANEL_PASSWORD=change-me

REMINDER_POLL_INTERVAL_SECONDS=60
AI_TIMEOUT_SECONDS=45

OPENROUTER_VISION_MODELS=google/gemma-4-31b-it:free,nvidia/nemotron-nano-2-vl:free,qwen/qwen3.6-plus:free
OPENROUTER_CHAT_MODELS=qwen/qwen3.6-plus:free,stepfun/step-3.5-flash:free,nvidia/nemotron-3-super:free,z-ai/glm-4.5-air:free
OPENROUTER_EMERGENCY_MODELS=stepfun/step-3.5-flash:free,nvidia/nemotron-3-nano-30b-a3b:free,z-ai/glm-4.5-air:free,meta-llama/llama-3.2-3b-instruct:free

GROQ_VISION_MODELS=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_CHAT_MODELS=llama-3.3-70b-versatile,llama-3.1-8b-instant
GROQ_EMERGENCY_MODELS=llama-3.1-8b-instant

HYPERBOLIC_VISION_MODELS=Qwen/Qwen2-VL-72B-Instruct,meta-llama/Llama-3.2-11B-Vision-Instruct
HYPERBOLIC_CHAT_MODELS=Qwen/Qwen2.5-72B-Instruct,meta-llama/Meta-Llama-3.1-70B-Instruct
HYPERBOLIC_EMERGENCY_MODELS=meta-llama/Meta-Llama-3.1-8B-Instruct
